{
  "version": 2,
  "functions": {
    "api/transcribe.js": { "maxDuration": 30 },
    "api/detect.js":     { "maxDuration": 15 },
    "api/gesture.js":    { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Audio-Type" }
      ]
    }
  ]
}
